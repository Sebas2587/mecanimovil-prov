# Google OAuth — App Proveedores (Firebase: mecanimovilapp)
# Copia a .env y completa iOS cuando tengas el Client ID en Google Cloud.

# Android (client_type 1 en google-services.json → com.mecanimovil.proveedores)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=85359766939-vod9ceeb0fj4p8c7pvmp31flk0ai56fm.apps.googleusercontent.com

# iOS (crear en GCP → Credentials → iOS, bundle com.mecanimovil.proveedores)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Web (client_type 3; también webClientId en Android nativo)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=85359766939-cjebsrg7s5s48sumoh3gio83jf5tskj9.apps.googleusercontent.com
