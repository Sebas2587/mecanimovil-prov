{
  "expo": {
    "name": "MecaniMóvil Proveedores",
    "slug": "mecanimovil-app-proveedores",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "splash": {
      "backgroundColor": "#ffffff",
      "dark": {
        "backgroundColor": "#0a0b0d"
      }
    },
    "scheme": "mecanimovilappproveedores",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mecanimovil.proveedores",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#000000"
      },
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "package": "com.mecanimovil.proveedores",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "mecanimovilappproveedores",
              "host": "mercadopago",
              "pathPrefix": "/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/app-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0a0b0d"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "La aplicación accede a tus fotos para subir documentos de verificación.",
          "cameraPermission": "La aplicación accede a tu cámara para tomar fotos de documentos.",
          "microphonePermission": "La aplicación necesita acceso al micrófono para usar la cámara."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "La aplicación accede a tu ubicación para servicios de localización."
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#0052FF",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.REVERSED_IOS_CLIENT_ID_AQUI"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "serverHost": {},
      "serverPort": 8000,
      "apiUrl": "https://mecanimovil-api.onrender.com/api",
      "forceLocalhost": false,
      "useNgrok": false,
      "ngrokUrl": {},
      "productionApiUrl": "https://mecanimovil-api.onrender.com",
      "forceProduction": true,
      "eas": {
        "projectId": "934a3f58-256e-499b-a14b-6ad252eba296"
      }
    },
    "owner": "sebas2587"
  }
}
